<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="10dp"
    android:layout_marginTop="20dp"
    android:background="@drawable/review_card_shape"
    android:orientation="horizontal"
    android:paddingStart="10dp">

    <ImageButton
        android:id="@+id/game_image"
        android:layout_width="80dp"
        android:layout_height="120dp"
        android:layout_gravity="center|start"
        android:layout_marginVertical="5dp"
        android:background="@drawable/game_miniature_shape"
        android:clipToOutline="true"
        android:scaleType="centerCrop" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginVertical="10dp"
        android:layout_marginStart="20dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/game_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:fontFamily="@font/upheavtt"
            android:textColor="@color/white"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/game_platforms"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:fontFamily="@font/m6x11plus"
            android:textColor="#A2A2A2"
            android:textSize="18sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:fontFamily="@font/m6x11plus"
            android:text="Fecha de salida:"
            android:textColor="@color/white"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/game_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/m6x11plus"
            android:textColor="#9C9C9C"
            android:textSize="18sp" />
    </LinearLayout>
</LinearLayout>