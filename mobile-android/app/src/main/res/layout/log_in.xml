<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/log_in"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1B1F27">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="top|center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0">

        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="73dp"
            android:background="#2D333E" />

        <TextView
            android:id="@+id/textView"
            android:layout_width="411dp"
            android:layout_height="87dp"
            android:fontFamily="@font/upheavtt"
            android:paddingTop="30dp"
            android:paddingBottom="20dp"
            android:text="BIENVENID@"
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="48sp" />

        <TextView
            android:id="@+id/textView2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/upheavtt"
            android:paddingTop="21dp"
            android:layout_marginBottom="50dp"
            android:text="NOS ALEGRA VERTE DE NUEVO!!! :)"
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="27sp" />

        <TextView
            android:id="@+id/textView9"
            android:layout_width="411dp"
            android:layout_height="29dp"
            android:fontFamily="@font/upheavtt"
            android:paddingStart="30dp"
            android:text="correo electrónico"
            android:textAlignment="textStart"
            android:letterSpacing="0.05"
            android:textColor="#FFFFFF"
            android:textSize="20sp" />

        <EditText
            android:id="@+id/editTextTextEmailAddress"
            android:layout_width="380dp"
            android:layout_height="50dp"
            android:background="@drawable/form_shape"
            android:ems="10"
            android:fontFamily="@font/m6x11plus"
            android:hint="tucorreo@dominio.com"
            android:inputType="textEmailAddress"
            android:letterSpacing="0.05"
            android:paddingStart="20dp"
            android:textAlignment="textStart"
            android:textColor="#828282"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/textView10"
            android:layout_width="match_parent"
            android:layout_height="29dp"
            android:layout_marginTop="40dp"
            android:fontFamily="@font/upheavtt"
            android:paddingStart="30dp"
            android:text="contraseña"
            android:letterSpacing="0.05"
            android:textAlignment="textStart"
            android:textColor="#FFFFFF"
            android:textSize="20sp" />

        <EditText
            android:id="@+id/editTextTextPassword"
            android:layout_width="380dp"
            android:layout_height="50dp"
            android:background="@drawable/form_shape"
            android:ems="10"
            android:fontFamily="@font/upheavtt"
            android:hint="******"
            android:inputType="textPassword"
            android:letterSpacing="0.2"
            android:paddingStart="20dp"
            android:textColor="#818181" />

        <Button
            android:id="@+id/forgotPasswordBtn"
            android:layout_width="match_parent"
            android:layout_height="37dp"
            android:background="#00FFFFFF"
            android:fontFamily="@font/m6x11plus"
            android:text="Olvidé mi contraseña"
            android:textAlignment="viewEnd"
            android:textColor="#29CDF2"
            android:textSize="20sp"
            android:fitsSystemWindows="true"/>

        <Button
            android:id="@+id/logInBtn"
            android:layout_width="380dp"
            android:layout_height="50dp"
            android:background="@drawable/button_shape"
            android:fontFamily="@font/upheavtt"
            android:text="ENTRAR"
            android:layout_marginTop="50dp"
            android:textSize="34sp"
            app:backgroundTint="@null" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="92dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="50dp"
            android:paddingTop="35dp">


            <TextView
                android:id="@+id/woutAccount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:fontFamily="@font/m6x11plus"
                android:letterSpacing="0.03"
                android:text="¿No tienes cuenta?"
                android:textColor="#FFFFFF"
                android:textSize="24sp" />

            <Button
                android:id="@+id/registerBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top|center"
                android:layout_weight="1"
                android:background="#00FFFFFF"
                android:fontFamily="@font/m6x11plus"
                android:text="Registrate!"
                android:textAlignment="viewStart"
                android:textColor="#29CDF2"
                android:textSize="24dp"
                app:iconTint="#00000000"
                app:rippleColor="#00FFFFFF" />

        </LinearLayout>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>