<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="50dp"
    android:layout_margin="8dp"
    app:cardCornerRadius="40dp"
    app:cardBackgroundColor="#2D333E"
    >

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:animateLayoutChanges="true"
        android:background="@drawable/accordion_shape"
        >

        <TextView
            android:id="@+id/accordion_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:padding="13dp"
            android:layout_marginLeft="10dp"
            android:text="Ordenar por:"
            android:fontFamily="@font/upheavtt"
            android:textColor="@color/white"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
            android:textSize="24sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/arrow_icon"/>

        <ImageView
            android:id="@+id/arrow_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_arrow_down"
            android:layout_marginRight="15dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="@+id/accordion_title"/>

        <!-- Contenido expandible (inicialmente oculto) -->
        <LinearLayout
            android:id="@+id/expandable_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginVertical="5dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/accordion_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <Button
                android:id="@+id/releaseDateAccordionGamesProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#00FFFFFF"
                android:textColor="@color/white"
                android:fontFamily="@font/m6x11plus"
                android:textSize="24sp"
                android:letterSpacing="0.05"
                android:text="Fecha de publicación"/>
            <Button
                android:id="@+id/nameAccordionGamesProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#00FFFFFF"
                android:textColor="@color/white"
                android:fontFamily="@font/m6x11plus"
                android:textSize="24sp"
                android:letterSpacing="0.05"
                android:text="Nombre"/>

            <Button
                android:id="@+id/ratingAccordionGamesProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#00FFFFFF"
                android:textColor="@color/white"
                android:fontFamily="@font/m6x11plus"
                android:textSize="24sp"
                android:letterSpacing="0.05"
                android:text="Calificación" />
            <Button
                android:id="@+id/LatestAddedAccordionGamesProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#00FFFFFF"
                android:textColor="@color/white"
                android:fontFamily="@font/m6x11plus"
                android:textSize="24sp"
                android:letterSpacing="0.05"
                android:text="Añadido recientemente" />



    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>