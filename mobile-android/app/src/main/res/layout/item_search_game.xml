<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="8dp"
    android:background="?android:attr/selectableItemBackground">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/searchGameImage"
        android:layout_width="45dp"
        android:layout_height="65dp"
        android:scaleType="centerCrop"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        app:shapeAppearanceOverlay="@style/rounded_corners" />

    <TextView
        android:id="@+id/searchGameTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:fontFamily="@font/m6x11plus"
        android:maxLines="2"
        android:ellipsize="end" />

    <Button
        android:id="@+id/btnAddToList"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="+"
        android:textSize="20sp"
        android:backgroundTint="#0466C8"
        android:fontFamily="@font/upheavtt"
        android:textColor="@color/white"
        android:minWidth="48dp" />

</LinearLayout>
