<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@drawable/button_shape"
    android:backgroundTint="#2D333E"
    android:padding="8dp">

    <TextView
        android:id="@+id/listTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:fontFamily="@font/upheavtt"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:paddingHorizontal="8dp"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/listAuthor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/upheavtt"
        android:layout_gravity="center"
        android:textColor="#A8A8A8"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="center">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginVertical="8dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/cover3"
                android:layout_width="100dp"
                android:layout_height="162dp"
                android:layout_marginStart="-80dp"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/rounded_corners"
                app:layout_constraintStart_toEndOf="@+id/cover2"
                app:layout_constraintBottom_toBottomOf="@+id/cover2" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/cover2"
                android:layout_width="100dp"
                android:layout_height="162dp"
                android:layout_marginStart="-80dp"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/rounded_corners"
                app:layout_constraintStart_toEndOf="@+id/cover1"
                app:layout_constraintBottom_toBottomOf="@+id/cover1" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/cover1"
                android:layout_width="111dp"
                android:layout_height="162dp"
                android:layout_marginStart="-80dp"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/rounded_corners"
                app:layout_constraintEnd_toEndOf="@id/cover2"
                app:layout_constraintTop_toTopOf="@id/cover2" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

</LinearLayout>
