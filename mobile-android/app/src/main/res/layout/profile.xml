<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1B1F27"
    android:fitsSystemWindows="true"
    android:visibility="visible">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/linearLayout3"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginBottom="5dp"
                android:orientation="horizontal">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/pfp_icon"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_gravity="center"
                    android:layout_marginStart="10dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/image"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.App.CircleImageView" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:paddingStart="15dp"
                    android:paddingEnd="0dp">

                    <Button
                        android:id="@+id/friendsProfile"
                        android:layout_width="150dp"
                        android:layout_height="48dp"
                        android:layout_gravity="end"
                        android:layout_marginVertical="15dp"
                        android:layout_marginEnd="15dp"
                        android:background="@drawable/button_shape"
                        android:fontFamily="@font/upheavtt"
                        android:text="AMIGOS"
                        android:textSize="25sp"
                        app:backgroundTint="#33415C" />

                    <TextView
                        android:id="@+id/username"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="7dp"
                        android:fontFamily="@font/upheavtt"
                        android:letterSpacing="0.05"
                        android:text="GORDON FREEMAN"
                        android:textColor="#FFFFFF"
                        android:textSize="25sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/textView18"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/upheavtt"
                            android:letterSpacing="0.05"
                            android:text="SE UNIÓ EL "
                            android:textColor="#FFFFFF"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/textView19"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/upheavtt"
                            android:letterSpacing="0.05"
                            android:text="19-11-1998"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <View
                android:id="@+id/divider3"
                android:layout_width="392dp"
                android:layout_height="1dp"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:background="#818387" />

            <LinearLayout
                android:id="@+id/linearLayout4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/gamesProfileBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="#00FFFFFF"
                        android:fontFamily="@font/upheavtt"
                        android:text="JUEGOS"
                        android:textColor="#FFFFFF"
                        android:textSize="30sp" />

                    <Button
                        android:id="@+id/wishlistProfileBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="#00FFFFFF"
                        android:fontFamily="@font/upheavtt"
                        android:text="wishlist"
                        android:textColor="#FFFFFF"
                        android:textSize="30sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/reviewsProfileBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="#00FFFFFF"
                        android:fontFamily="@font/upheavtt"
                        android:text="REVIEWS"
                        android:textColor="#FFFFFF"
                        android:textSize="30sp" />

                    <Button
                        android:id="@+id/listProfileBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="#00FFFFFF"
                        android:fontFamily="@font/upheavtt"
                        android:text="LISTAS"
                        android:textColor="#FFFFFF"
                        android:textSize="30sp" />
                </LinearLayout>

            </LinearLayout>

            <View
                android:id="@+id/divider4"
                android:layout_width="392dp"
                android:layout_height="1dp"
                android:layout_marginStart="10dp"
                android:layout_marginTop="7dp"
                android:layout_marginEnd="10dp"
                android:background="#818387" />

            <TextView
                android:id="@+id/textView17"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/upheavtt"
                android:text="Juegos favoritos"
                android:textColor="@color/white"
                android:textSize="24sp" />

            <View
                android:id="@+id/divider5"
                android:layout_width="230dp"
                android:layout_height="1dp"
                android:layout_marginStart="10dp"
                android:layout_marginTop="5dp"
                android:layout_marginEnd="151dp"
                android:background="#818387" />

            <HorizontalScrollView
                android:id="@+id/horizontalScrollView"
                android:layout_width="411dp"
                android:layout_height="200dp">

                <LinearLayout
                    android:id="@+id/linearLayout2"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">

                    <ImageButton
                        android:id="@+id/game_ds3"
                        android:layout_width="111dp"
                        android:layout_height="162dp"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/game_miniature_shape"
                        android:clipToOutline="true"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ds3" />

                    <ImageButton
                        android:id="@+id/game_tboi"
                        android:layout_width="111dp"
                        android:layout_height="162dp"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/game_miniature_shape"
                        android:clipToOutline="true"
                        android:scaleType="centerCrop"
                        android:src="@drawable/tboi" />

                    <ImageButton
                        android:id="@+id/game_mhworld"
                        android:layout_width="111dp"
                        android:layout_height="162dp"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/game_miniature_shape"
                        android:clipToOutline="true"
                        android:scaleType="centerCrop"
                        android:src="@drawable/mhworld" />

                    <ImageButton
                        android:id="@+id/game1_ror2"
                        android:layout_width="111dp"
                        android:layout_height="162dp"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/game_miniature_shape"
                        android:clipToOutline="true"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ror2" />
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/textView20"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/upheavtt"
                android:text="Actividad Reciente"
                android:textColor="@color/white"
                android:textSize="24sp" />

            <View
                android:id="@+id/divider6"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="10dp"
                android:layout_marginTop="5dp"
                android:layout_marginEnd="151dp"
                android:background="#818387" />

            <HorizontalScrollView
                android:id="@+id/latestactivity"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:id="@+id/linearLayoutLatestActivity"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="30dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <ImageButton
                            android:id="@+id/game_deadspace"
                            android:layout_width="111dp"
                            android:layout_height="162dp"
                            android:layout_marginTop="20dp"
                            android:background="@drawable/game_miniature_shape"
                            android:clipToOutline="true"
                            android:scaleType="centerCrop"
                            android:src="@drawable/deadspace" />
                        <RatingBar
                            android:id="@+id/ratingBarReview"
                            style="?android:attr/ratingBarStyleSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginTop="4dp"
                            android:isIndicator="true"
                            android:numStars="5"
                            android:progressBackgroundTint="#626262"
                            android:progressTint="#FFCC00"
                            android:rating="1"
                            android:stepSize="0.5" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <ImageButton
                        android:id="@+id/game_dredge"
                        android:layout_width="111dp"
                        android:layout_height="162dp"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/game_miniature_shape"
                        android:clipToOutline="true"
                        android:scaleType="centerCrop"
                        android:src="@drawable/dredge" />

                        <RatingBar
                            android:id="@+id/ratingBarReview2"
                            style="?android:attr/ratingBarStyleSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginTop="4dp"
                            android:isIndicator="true"
                            android:numStars="5"
                            android:progressBackgroundTint="#626262"
                            android:progressTint="#FFCC00"
                            android:rating="4"
                            android:stepSize="0.5" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <ImageButton
                            android:id="@+id/game_mhwilds"
                            android:layout_width="111dp"
                            android:layout_height="162dp"
                            android:layout_marginStart="16dp"
                            android:layout_marginTop="20dp"
                            android:background="@drawable/game_miniature_shape"
                            android:clipToOutline="true"
                            android:scaleType="centerCrop"
                            android:src="@drawable/mhwilds" />
                        <RatingBar
                            android:id="@+id/ratingBarReview3"
                            style="?android:attr/ratingBarStyleSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginTop="4dp"
                            android:isIndicator="true"
                            android:numStars="5"
                            android:progressBackgroundTint="#626262"
                            android:progressTint="#FFCC00"
                            android:rating="5"
                            android:stepSize="0.5" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <ImageButton
                            android:id="@+id/game1_gow"
                            android:layout_width="111dp"
                            android:layout_height="162dp"
                            android:layout_marginStart="16dp"
                            android:layout_marginTop="20dp"
                            android:background="@drawable/game_miniature_shape"
                            android:clipToOutline="true"
                            android:scaleType="centerCrop"
                            android:src="@drawable/gow" />
                        <RatingBar
                            android:id="@+id/ratingBarReview4"
                            style="?android:attr/ratingBarStyleSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginTop="4dp"
                            android:isIndicator="true"
                            android:numStars="5"
                            android:progressBackgroundTint="#626262"
                            android:progressTint="#FFCC00"
                            android:rating="4.5"
                            android:stepSize="0.5" />
                    </LinearLayout>
                </LinearLayout>
            </HorizontalScrollView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

