<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1B1F27"
    android:fitsSystemWindows="true"
    android:visibility="visible">

    <TextView
        android:id="@+id/textView21"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="82dp"
        android:layout_marginEnd="83dp"
        android:layout_marginVertical="20dp"
        android:fontFamily="@font/upheavtt"
        android:text="GORDON FREEMAN"
        android:textColor="@color/white"
        android:textSize="30dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

    </TextView>

    <View
        android:id="@+id/divider7"
        android:layout_width="392dp"
        android:layout_height="1dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="5dp"
        android:layout_marginEnd="10dp"
        android:background="#818387"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView21" />

    <LinearLayout
        android:id="@+id/linearLayout4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/textView21">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:layout_weight="1"
            android:orientation="vertical">

            <Button
                android:id="@+id/gamesProfileBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="#00FFFFFF"
                android:fontFamily="@font/upheavtt"
                android:text="JUEGOS"
                android:textColor="#FFFFFF"
                android:textSize="30sp" />

            <Button
                android:id="@+id/wishlistProfileBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="#00FFFFFF"
                android:fontFamily="@font/upheavtt"
                android:text="wishlist"
                android:textColor="#FFFFFF"
                android:textSize="30sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:orientation="vertical">

            <Button
                android:id="@+id/reviewsProfileBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="#00FFFFFF"
                android:fontFamily="@font/upheavtt"
                android:text="REVIEWS"
                android:textColor="#FFFFFF"
                android:textSize="30sp" />

            <Button
                android:id="@+id/listProfileBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="#00FFFFFF"
                android:fontFamily="@font/upheavtt"
                android:text="LISTAS"
                android:textColor="#29CDF2"
                android:textSize="30sp" />
        </LinearLayout>

    </LinearLayout>

    <View
        android:id="@+id/divider8"
        android:layout_width="392dp"
        android:layout_height="1dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="5dp"
        android:layout_marginEnd="10dp"
        android:background="#818387"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout4" />

    <LinearLayout
        android:id="@+id/linearLayout5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/divider8"
        tools:layout_editor_absoluteX="0dp">

        <Button
            android:id="@+id/button"
            android:layout_width="73dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_weight="1"
            android:background="@drawable/button_shape"
            android:fontFamily="@font/m6x11plus"
            android:text="Buscar lista"
            android:textSize="24sp"
            app:backgroundTint="#0466C8" />

        <Button
            android:id="@+id/button2"
            android:layout_width="73dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_weight="1"
            android:background="@drawable/button_shape"
            android:fontFamily="@font/m6x11plus"
            android:text="+ Crear lista"
            android:textSize="24sp"
            app:backgroundTint="#0466C8" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="676dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout5"
        tools:layout_editor_absoluteX="0dp">
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:paddingHorizontal="10dp"
            >
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_gravity="center"
                android:background="@drawable/button_shape"
                android:backgroundTint="#2D333E"
                >

                <Button
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#00FFFFFF"
                    android:layout_gravity="center"
                    android:fontFamily="@font/upheavtt"
                    android:text="Roguelike"
                    android:textSize="24sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/upheavtt"
                    android:text="by Gordon Freeman"
                    android:layout_gravity="center"
                    android:textColor="#A8A8A8"
                    android:textSize="14sp"/>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_gravity="center">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/image_container1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="8dp"
                        app:layout_constraintStart_toStartOf="parent">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/image_back1"
                            android:layout_width="100dp"
                            android:layout_height="162dp"
                            android:layout_marginStart="-80dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ballxpit"
                            app:shapeAppearanceOverlay="@style/rounded_corners"
                            app:layout_constraintStart_toEndOf="@+id/image_middle1"
                            app:layout_constraintBottom_toBottomOf="@+id/image_middle1" />

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/image_middle1"
                            android:layout_width="100dp"
                            android:layout_height="162dp"
                            android:layout_marginStart="-80dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ror2"
                            app:shapeAppearanceOverlay="@style/rounded_corners"
                            app:layout_constraintStart_toEndOf="@+id/image_front1"
                            app:layout_constraintBottom_toBottomOf="@+id/image_front1" />

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/image_front1"
                            android:layout_width="111dp"
                            android:layout_height="162dp"
                            android:layout_marginStart="-80dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/tboi"
                            app:shapeAppearanceOverlay="@style/rounded_corners"
                            app:layout_constraintEnd_toEndOf="@id/image_middle1"
                            app:layout_constraintTop_toTopOf="@id/image_middle1"/>

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_gravity="center"
                android:background="@drawable/button_shape"
                android:backgroundTint="#2D333E"
                android:layout_margin="8dp">

                <Button
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#00FFFFFF"
                    android:layout_gravity="center"
                    android:fontFamily="@font/upheavtt"
                    android:text="Peak games"
                    android:textSize="24sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/upheavtt"
                    android:text="by Gordon Freeman"
                    android:layout_gravity="center"
                    android:textColor="#A8A8A8"
                    android:textSize="14sp"/>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_gravity="center">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/image_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="8dp"
                        app:layout_constraintStart_toStartOf="parent">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/image_back"
                            android:layout_width="100dp"
                            android:layout_height="162dp"
                            android:layout_marginStart="-80dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/yakuzapirate"
                            app:shapeAppearanceOverlay="@style/rounded_corners"
                            app:layout_constraintStart_toEndOf="@+id/image_middle"
                            app:layout_constraintBottom_toBottomOf="@+id/image_middle" />

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/image_middle"
                            android:layout_width="100dp"
                            android:layout_height="162dp"
                            android:layout_marginStart="-80dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/mhwilds"
                            app:shapeAppearanceOverlay="@style/rounded_corners"
                            app:layout_constraintStart_toEndOf="@+id/image_front"
                            app:layout_constraintBottom_toBottomOf="@+id/image_front" />

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/image_front"
                            android:layout_width="111dp"
                            android:layout_height="162dp"
                            android:layout_marginStart="-80dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/mhworld"
                            app:shapeAppearanceOverlay="@style/rounded_corners"
                            app:layout_constraintEnd_toEndOf="@id/image_middle"
                            app:layout_constraintTop_toTopOf="@id/image_middle"/>

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>

            </LinearLayout>

        </GridLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>