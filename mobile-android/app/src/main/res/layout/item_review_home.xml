<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="10dp"
    android:layout_marginTop="20dp"
    android:background="@drawable/review_card_shape"
    android:orientation="horizontal"
    android:paddingStart="10dp">

    <ImageButton
        android:id="@+id/game_image_review"
        android:layout_width="70dp"
        android:layout_height="110dp"
        android:layout_gravity="center|start"
        android:layout_marginVertical="10dp"
        android:background="@drawable/game_miniature_shape"
        android:clipToOutline="true"
        android:scaleType="centerCrop"
        android:src="@drawable/ballxpit" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/user_pfp_review"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginHorizontal="10dp"
        android:layout_marginTop="10dp"
        android:scaleType="centerCrop"
        android:src="@drawable/image"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.CircleImageView" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginVertical="10dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingEnd="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/user_name_review"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_weight="1"
                android:fontFamily="@font/upheavtt"
                android:text="Usuario"
                android:textColor="@color/white"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/review_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/m6x11plus"
                android:text="4d"
                android:textColor="#A2A2A2"
                android:textSize="16sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/review_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="5dp"
            android:fontFamily="@font/m6x11plus"
            android:ellipsize="end"
            android:maxLines="3"
            android:text="Contenido de la reseña..."
            android:textColor="#9C9C9C"
            android:textSize="16sp" />

        <RatingBar
            android:id="@+id/ratingBarReview"
            style="?android:attr/ratingBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:isIndicator="true"
            android:numStars="5"
            android:progressBackgroundTint="#626262"
            android:progressTint="#FFCC00"
            android:stepSize="0.5" />
    </LinearLayout>
</LinearLayout>