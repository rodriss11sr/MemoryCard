<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#2D333E"
    app:cardCornerRadius="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AÑADIR JUEGO"
            android:textColor="@color/white"
            android:fontFamily="@font/upheavtt"
            android:textSize="24sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="10dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#444444"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivReviewGameCover"
                android:layout_width="100dp"
                android:layout_height="140dp"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/rounded_corners"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="15dp">

                <TextView
                    android:id="@+id/tvReviewGameTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:fontFamily="@font/upheavtt"/>

                <EditText
                    android:id="@+id/etReviewText"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:background="@drawable/button_shape"
                    android:backgroundTint="@color/white"
                    android:gravity="top"
                    android:padding="10dp"
                    android:fontFamily="@font/m6x11plus"
                    android:hint="Añadir review..."
                    android:textSize="18sp"
                    android:layout_marginTop="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rating"
                        android:textSize="18sp"
                        android:textColor="@color/white"
                        android:fontFamily="@font/upheavtt"
                        android:layout_marginEnd="10dp"/>

                    <RatingBar
                        android:id="@+id/reviewRatingBar"
                        style="?android:attr/ratingBarStyleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:numStars="5"
                        android:stepSize="0.5"
                        android:isIndicator="false"
                        android:progressTint="#FFCC00"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnAddFinal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AÑADIR"
            android:textSize="20sp"
            android:layout_gravity="end"
            android:layout_marginTop="20dp"
            android:backgroundTint="#0066CC"
            android:fontFamily="@font/upheavtt"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>