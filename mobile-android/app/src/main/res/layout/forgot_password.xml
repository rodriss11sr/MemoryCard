<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#1B1F27">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="top|center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0">

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="73dp"
        android:background="#2D333E" />

        <TextView
            android:id="@+id/textView"
            android:layout_width="411dp"
            android:layout_height="161dp"
            android:fontFamily="@font/m6x11plus"
            android:paddingStart="20dp"
            android:layout_marginTop="40dp"
            android:paddingBottom="20dp"
            android:layout_marginBottom="50dp"
            android:text="Ingresa el email de tu cuenta y te enviaremos un correo para recuperar la cuenta"
            android:textAlignment="textStart"
            android:textColor="#FFFFFF"
            android:textSize="34sp" />

        <TextView
            android:id="@+id/textView9"
            android:layout_width="411dp"
            android:layout_height="29dp"
            android:fontFamily="@font/upheavtt"
            android:paddingStart="30dp"
            android:text="correo electrónico"
            android:textAlignment="textStart"
            android:letterSpacing="0.05"
            android:textColor="#FFFFFF"
            android:textSize="20sp" />

        <EditText
            android:id="@+id/editTextTextEmailAddress"
            android:layout_width="380dp"
            android:layout_height="50dp"
            android:background="@drawable/form_shape"
            android:ems="10"
            android:fontFamily="@font/m6x11plus"
            android:hint="tucorreo@dominio.com"
            android:inputType="textEmailAddress"
            android:letterSpacing="0.05"
            android:paddingStart="20dp"
            android:textAlignment="textStart"
            android:textColor="#828282"
            android:textSize="20sp" />

        <Button
            android:id="@+id/recoverPasswordBtn"
            android:layout_width="380dp"
            android:layout_height="50dp"
            android:background="@drawable/button_shape"
            android:fontFamily="@font/upheavtt"
            android:text="Recuperar"
            android:layout_marginTop="50dp"
            android:textSize="34sp"
            app:backgroundTint="@null" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="50dp"
            android:paddingTop="20dp">


            <TextView
                android:id="@+id/woutAccount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:fontFamily="@font/m6x11plus"
                android:letterSpacing="0.03"
                android:text="¿No tienes cuenta?"
                android:textColor="#FFFFFF"
                android:textSize="24sp" />

            <Button
                android:id="@+id/registerBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top|center"
                android:layout_weight="1"
                android:background="#00FFFFFF"
                android:fontFamily="@font/m6x11plus"
                android:text="Registrate!"
                android:textAlignment="textStart"
                android:textColor="#29CDF2"
                android:textSize="24dp"
                app:iconTint="#00000000"
                app:rippleColor="#00FFFFFF" />

        </LinearLayout>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>