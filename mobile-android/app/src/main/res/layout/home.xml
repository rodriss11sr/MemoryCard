<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/homeScreen"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1B1F27"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="top|center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0">

        <View
            android:id="@+id/divider2"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="#2D333E" />

        <TextView
            android:id="@+id/archiveText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/upheavtt"
            android:paddingBottom="40dp"
            android:paddingTop="30dp"
            android:text="@string/archive"
            android:textColor="#FFFFFF"
            android:textSize="48sp" />

        <Button
            android:id="@+id/logInButton"
            android:layout_width="345dp"
            android:layout_height="59dp"
            android:backgroundTint="#0466C8"
            android:fontFamily="@font/upheavtt"
            android:text="INICIAR SESIÓN"
            android:textSize="24sp" />

        <LinearLayout
            android:layout_width="391dp"
            android:layout_height="79dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingTop="35dp">


            <TextView
                android:id="@+id/woutAccount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:fontFamily="@font/m6x11plus"
                android:text="¿No tienes cuenta?"
                android:textColor="#FFFFFF"
                android:textSize="24sp" />

            <TextView
                android:id="@+id/registerText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:fontFamily="@font/m6x11plus"
                android:paddingLeft="10dp"
                android:paddingRight="0dp"
                android:text="Registrate!"
                android:textColor="#29CDF2"
                android:textSize="24sp" />

        </LinearLayout>

        <View
            android:id="@+id/divider3"
            android:layout_width="392dp"
            android:layout_height="1dp"
            android:background="#E6E6E6" />


    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>