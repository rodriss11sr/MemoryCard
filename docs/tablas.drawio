                <mxCell id="32" value="Las tablas &quot;lista&quot; y &quot;reseña&quot;, al tener relaciones 1:n con otras entidades&lt;div&gt;que forman la base de datos, se les añaden las claves primarias de estas&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=#6c8ebf;fillColor=#dae8fc;" parent="1" vertex="1">
